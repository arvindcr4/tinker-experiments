Assistant: Here's a Bash script that will append each file's creation date to its name:

for file in *; do
  year=$(stat -f "%Sm" -t "%Y" $file);
  month=$(stat -f "%Sm" -t "%m" $file);
  if [ $year -eq $(date +%Y) ]; then
    mv $file $file-$month;
  else
    mv $file $file-$year;
  fi;
done

